{
  "model_dir": "saved_models",
  "plot_dir": "plots",
  "data_dir": "Dataset",
  "feature_cols": [
    "Potential",
    "OXIDATION",
    "Zn_Co_Conc",
    "Scan_Rate",
    "ZN",
    "CO",
    "Temperature",
    "Electrode_Area"
  ],
  "target_col": "Current_Density",
  "architecture": "ann",
  "hidden_units": [
    256,
    128,
    64,
    32
  ],
  "dropout_rate": 0.05,
  "mc_dropout": true,
  "lambda_faraday": 0.001,
  "lambda_capacitance": 0.001,
  "lambda_redox": 0.001,
  "lambda_smooth": 0.001,
  "lambda_butler_volmer": 0.0005,
  "lambda_nernst": 0.0005,
  "lambda_charge_conservation": 0.001,
  "lambda_randles_sevcik": 0.0005,
  "lambda_thermodynamic": 0.0002,
  "max_current": 5000.0,
  "epochs": 500,
  "batch_size": 256,
  "learning_rate": 0.005,
  "min_lr": 1e-06,
  "patience": 50,
  "warmup_epochs": 80,
  "test_size": 0.15,
  "val_size": 0.15,
  "seed": 42,
  "mc_samples": 50,
  "augment": true,
  "use_cosine_annealing": true,
  "cosine_T_0": 100,
  "cosine_T_mult": 2
}